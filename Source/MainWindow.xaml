<Window x:Class="CodexWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 额度桌面挂件" Width="380" Height="802"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="DataText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5C341E" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style x:Key="TinyButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Foreground" Value="#6D3B1E" />
            <Setter Property="Background" Value="#FFF3D0" />
            <Setter Property="BorderBrush" Value="#B96A39" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <Grid x:Name="RootGrid" Width="380" Height="802" Background="Transparent"
              MouseLeftButtonDown="Root_MouseLeftButtonDown" MouseRightButtonUp="Root_MouseRightButtonUp">
            <Grid.ContextMenu>
                <ContextMenu x:Name="WidgetMenu">
                    <MenuItem x:Name="MenuSettings" Header="⚙ 设置…" Click="Settings_Click" />
                    <MenuItem x:Name="MenuRefresh" Header="↻ 立即刷新" Click="Refresh_Click" />
                    <MenuItem x:Name="MenuLogin" Header="🔐 登录 / 官方用量页" Click="Login_Click" />
                    <Separator />
                    <MenuItem x:Name="MenuProvider" Header="平台">
                        <MenuItem Header="Codex" Tag="Codex" Click="ProviderMenu_Click" />
                        <MenuItem Header="Gemini" Tag="Gemini" Click="ProviderMenu_Click" />
                        <MenuItem Header="Claude" Tag="Claude" Click="ProviderMenu_Click" />
                    </MenuItem>
                    <MenuItem x:Name="MenuCharacter" Header="角色" />
                    <MenuItem x:Name="ClickThroughMenu" Header="鼠标穿透" IsCheckable="True" Click="ClickThroughMenu_Click" />
                    <MenuItem x:Name="MenuHotkeys" Header="⌨ 快捷键说明" Click="Hotkeys_Click" />
                    <Separator />
                    <MenuItem x:Name="MenuExit" Header="退出" Click="Close_Click" />
                </ContextMenu>
            </Grid.ContextMenu>

            <Image x:Name="MascotImage" Source="Assets/Doraemon/default.png" Stretch="Fill" IsHitTestVisible="False"
                   RenderTransformOrigin="0.5,0.96">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="MascotScale" />
                        <RotateTransform x:Name="MascotRotate" />
                        <TranslateTransform x:Name="MascotTranslate" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>

            <Border x:Name="BoardBorder" Margin="31,38,31,0" Height="281" VerticalAlignment="Top"
                    Background="#08FFF9E7" CornerRadius="20" Padding="18,13,18,10"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <RotateTransform x:Name="BoardRotate" />
                        <TranslateTransform x:Name="BoardTranslate" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <TextBlock x:Name="DashboardTitle" Text="CODEX 能量看板" Foreground="#E66B25" FontSize="21"
                                   FontWeight="Bold" FontFamily="Microsoft YaHei UI" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource TinyButton}" x:Name="RandomButton" Content="🎲" ToolTip="随机换人物" Click="RandomCharacter_Click" />
                            <Button Style="{StaticResource TinyButton}" Content="⚙" ToolTip="设置" Click="Settings_Click" />
                            <Button Style="{StaticResource TinyButton}" Content="↻" ToolTip="立即刷新" Click="Refresh_Click" />
                            <Button Style="{StaticResource TinyButton}" Content="×" ToolTip="退出" Click="Close_Click" />
                        </StackPanel>
                    </DockPanel>
                    <StackPanel Grid.Row="1" Margin="0,8,0,2">
                        <TextBlock x:Name="FiveUsage" Style="{StaticResource DataText}" Text="⏱ 5小时用量：同步中…" />
                        <TextBlock x:Name="FiveReset" Style="{StaticResource DataText}" FontSize="12" Foreground="#8B624A" Text="   重置时间：—" />
                        <Separator Margin="0,5" Background="#E8B88D" />
                        <TextBlock x:Name="WeekUsage" Style="{StaticResource DataText}" Text="📅 周用量：同步中…" />
                        <TextBlock x:Name="WeekReset" Style="{StaticResource DataText}" FontSize="12" Foreground="#8B624A" Text="   重置时间：—" />
                        <Separator x:Name="ExtraSeparator" Margin="0,5" Background="#E8B88D" />
                        <DockPanel x:Name="ExtraRow">
                            <!-- 融入看板的重置卡圆圈（仅 Codex） -->
                            <Border x:Name="CardBadge" DockPanel.Dock="Right" Width="30" Height="30" CornerRadius="15"
                                    Background="#F18A3D" BorderBrush="#FFFFFF" BorderThickness="2"
                                    VerticalAlignment="Center" ToolTip="重置卡可用张数">
                                <TextBlock x:Name="CardBadgeText" Text="—" FontSize="15" FontWeight="Bold" Foreground="White"
                                           FontFamily="Microsoft YaHei UI" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="ExtraUsage" Style="{StaticResource DataText}" Text="" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock x:Name="ExtraNoteText" Style="{StaticResource DataText}" FontSize="12" Foreground="#8B624A" Text="" />
                    </StackPanel>
                    <DockPanel Grid.Row="2">
                        <TextBlock x:Name="UpdatedAt" Text="等待同步" Foreground="#A0765D" FontSize="10" VerticalAlignment="Center" />
                        <Button x:Name="LoginButton" Content="登录" Padding="8,3" HorizontalAlignment="Right" FontSize="11"
                                Cursor="Hand" Background="#FFFFE8" BorderBrush="#E39758" Click="Login_Click" />
                    </DockPanel>
                </Grid>
            </Border>

        </Grid>
    </Viewbox>
</Window>
