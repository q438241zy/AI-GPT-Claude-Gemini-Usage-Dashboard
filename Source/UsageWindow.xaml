<Window x:Class="CodexWidget.UsageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 平台登录与用量同步" Width="620" Height="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FFF8EE">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="ProviderTitle" FontSize="25" FontWeight="Bold" Foreground="#D96022" />
            <TextBlock x:Name="HintText" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="14" Foreground="#6F4A31" />
        </StackPanel>
        <Border Grid.Row="1" Margin="0,22" Padding="18" Background="#FFFFD9" CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="ModeTitle" Text="真正登录模式" FontSize="18" FontWeight="Bold" Foreground="#955020" />
                <TextBlock x:Name="ModeBody" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="点击下面按钮后，会打开一个独立的 Microsoft Edge 窗口。" />
                <TextBlock x:Name="SyncStatus" Margin="0,16,0,0" Foreground="#9A5B30" Text="尚未连接官方页面" />
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOpen" Content="1. 打开 Edge 登录/用量页" Padding="14,7" Margin="5" Click="OpenUsage_Click" />
            <Button x:Name="BtnSync" Content="2. 登录完成，立即同步" Padding="14,7" Margin="5" Background="#F28B3B" Foreground="White" Click="Sync_Click" />
            <Button x:Name="BtnHide" Content="隐藏" Padding="14,7" Margin="5" Click="Done_Click" />
        </StackPanel>
    </Grid>
</Window>
