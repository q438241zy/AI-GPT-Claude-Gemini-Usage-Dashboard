<Window x:Class="CodexWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面额度挂件设置" Width="480" Height="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFF8EE">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" Text="桌面额度挂件设置" FontSize="25" FontWeight="Bold" Foreground="#D96022" />

        <StackPanel Grid.Row="1" Margin="0,18,0,10">
            <TextBlock x:Name="LanguageLabel" Text="语言 / Language / 言語" FontWeight="Bold" />
            <ComboBox x:Name="LanguageBox" Margin="0,5,0,12" Height="30" SelectionChanged="Control_Changed">
                <ComboBoxItem Content="中文" Tag="zh" />
                <ComboBoxItem Content="English" Tag="en" />
                <ComboBoxItem Content="日本語" Tag="ja" />
            </ComboBox>

            <TextBlock x:Name="ProviderLabel" Text="平台" FontWeight="Bold" />
            <ComboBox x:Name="ProviderBox" Margin="0,5,0,12" Height="30" SelectionChanged="Control_Changed">
                <ComboBoxItem Content="Codex" Tag="Codex" />
                <ComboBoxItem Content="Gemini" Tag="Gemini" />
                <ComboBoxItem Content="Claude" Tag="Claude" />
            </ComboBox>

            <TextBlock x:Name="BrowserLabel" Text="登录用浏览器" FontWeight="Bold" />
            <ComboBox x:Name="BrowserBox" Margin="0,5,0,12" Height="30" SelectionChanged="Control_Changed">
                <ComboBoxItem Content="Chrome" Tag="Chrome" />
                <ComboBoxItem Content="Edge" Tag="Edge" />
            </ComboBox>

            <TextBlock x:Name="CharacterLabel" Text="角色" FontWeight="Bold" />
            <DockPanel Margin="0,5,0,4">
                <ComboBox x:Name="CharacterBox" Height="30" Width="220" HorizontalAlignment="Left"
                          SelectionChanged="Control_Changed" />
                <Button x:Name="ImportImageButton" Content="导入 PNG / GIF…" Margin="10,0,0,0" Padding="10,3" Click="Browse_Click" />
            </DockPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="ImportPackButton" Content="导入角色包…" Padding="10,3" Click="ImportPack_Click" />
                <Button x:Name="OpenPackDirButton" Content="打开角色文件夹" Margin="8,0,0,0" Padding="10,3" Click="OpenPackDir_Click" />
            </StackPanel>

            <TextBlock x:Name="ScaleLabelTitle" Text="大小（实时生效）" FontWeight="Bold" />
            <DockPanel Margin="0,5,0,10">
                <TextBlock x:Name="ScaleLabel" Width="52" VerticalAlignment="Center" />
                <Slider x:Name="ScaleSlider" Minimum="0.45" Maximum="1.35" TickFrequency="0.05"
                        ValueChanged="ScaleSlider_ValueChanged" />
            </DockPanel>

            <TextBlock x:Name="OpacityLabelTitle" Text="透明度（实时生效）" FontWeight="Bold" />
            <DockPanel Margin="0,5,0,10">
                <TextBlock x:Name="OpacityLabel" Width="52" VerticalAlignment="Center" />
                <Slider x:Name="OpacitySlider" Minimum="0.25" Maximum="1" TickFrequency="0.05"
                        ValueChanged="OpacitySlider_ValueChanged" />
            </DockPanel>

            <CheckBox x:Name="AnimateCheck" Content="启用动态效果" Margin="0,4"
                      Checked="Control_Changed" Unchecked="Control_Changed" />
            <DockPanel Margin="20,2,0,8">
                <TextBlock x:Name="SpeedLabel" Text="动画速度" Width="90" VerticalAlignment="Center" />
                <Slider x:Name="SpeedSlider" Minimum="0.4" Maximum="2.5" Value="1" TickFrequency="0.1"
                        ValueChanged="Control_ValueChanged" />
            </DockPanel>
            <CheckBox x:Name="TopmostCheck" Content="永远置顶" Margin="0,4"
                      Checked="Control_Changed" Unchecked="Control_Changed" />
            <CheckBox x:Name="ClickThroughCheck" Content="鼠标穿透" Margin="0,4"
                      Checked="Control_Changed" Unchecked="Control_Changed" />

            <DockPanel Margin="0,8,0,0">
                <TextBlock x:Name="RefreshLabel" Text="自动刷新（分钟）" Width="140" VerticalAlignment="Center" />
                <TextBox x:Name="RefreshBox" Width="60" Text="5" TextChanged="Control_TextChanged" />
            </DockPanel>

            <Button x:Name="TestModeButton" Content="🧪 测试模式…" HorizontalAlignment="Left"
                    Margin="0,14,0,0" Padding="12,5" Click="TestMode_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="取消" Width="86" Margin="5" IsCancel="True" />
            <Button x:Name="SaveButton" Content="保存" Width="86" Margin="5" IsDefault="True" Click="Save_Click"
                    Background="#F18A3D" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
